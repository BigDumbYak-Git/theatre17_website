---
layout: base.njk
navActive: about
permalink: about.html
pageTitle: "About Us — Theatre 17"
pageDescription: "About Theatre 17 — Dryden's community theatre group since 1972."
---

{% set pg = about %}

<div class="page-header">
  <div class="container">
    <span class="kicker">{{ pg.page_header.kicker }}</span>
    <h1>{{ pg.page_header.heading }}</h1>
    <p>{{ pg.page_header.subheading }}</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="about-layout">

      <div class="about-content">
        {% for section in pg.content_sections %}
          <h2>{{ section.heading }}</h2>
          {{ section.body | markdown | safe }}
        {% endfor %}
      </div>

      <div class="about-sidebar">
        {% for card in pg.sidebar_cards %}

          {% if card.highlighted %}
            <div class="sidebar-card" style="background:var(--burgundy);border-color:var(--burgundy);">
              <h3 style="color:var(--white);">{{ card.heading }}</h3>
              {% if card.body %}
                <p style="color:rgba(255,255,255,0.75);font-size:0.88rem;margin-bottom:1.25rem;">{{ card.body }}</p>
              {% endif %}
              {% if card.button_label and card.button_url %}
                <a href="{{ card.button_url }}" class="btn btn-gold" style="width:100%;justify-content:center;font-size:0.78rem;">{{ card.button_label }}</a>
              {% endif %}
            </div>

          {% elif card.card_type == "cta" %}
            <div class="sidebar-card">
              <h3>{{ card.heading }}</h3>
              {% if card.body %}
                <p>{{ card.body }}</p>
              {% endif %}
              {% if card.button_label and card.button_url %}
                <a href="{{ card.button_url }}" class="btn btn-primary" style="width:100%;justify-content:center;">{{ card.button_label }}</a>
              {% endif %}
            </div>

          {% else %}
            <div class="sidebar-card">
              <h3>{{ card.heading }}</h3>
              {% if card.items and card.items.length %}
                <ul class="sidebar-list">
                  {% for item in card.items %}
                    <li><span class="sl-name">{{ item.label }}</span><span class="sl-role">{{ item.value }}</span></li>
                  {% endfor %}
                </ul>
              {% endif %}
              {% if card.footnote %}
                <p style="font-size:0.78rem;color:var(--ink-light);margin-top:0.75rem;font-style:italic;">{{ card.footnote }}</p>
              {% endif %}
            </div>

          {% endif %}

        {% endfor %}
      </div>

    </div>
  </div>
</section>
